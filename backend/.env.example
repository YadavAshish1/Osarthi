PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/osarthi
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-change-in-production-32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Cloudinary ---
# Easiest: paste the full "CLOUDINARY_URL" from Dashboard → API Keys (one line)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=osarthi
CLOUDINARY_ENABLED=true
